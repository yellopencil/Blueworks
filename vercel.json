{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    }
  ]
}
